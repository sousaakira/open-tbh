{
  "name": "idll-game",
  "version": "0.1.0",
  "description": "Idle RPG no estilo Taskbar Hero — Vite + Phaser + Electron",
  "main": "dist-electron/main.js",
  "scripts": {
    "normalize-assets": "node scripts/normalize-assets.mjs",
    "dev": "env -u ELECTRON_RUN_AS_NODE vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "tsc && vite build && electron-builder"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.idll.game",
    "productName": "IDLL Game",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  }
}
